# research_commons — environment variables
# Copy to .env and fill in real values.
# See README.md for full documentation.

# ---- Required: database connections ----------------------------------------
# Same Aiven cluster as the legacy defaultdb, different database names.
NEWS_DATABASE_URL=
MARKET_DATABASE_URL=

# ---- Required: LLM ----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-


# ---- Optional ---------------------------------------------------------------
GEMINI_API_KEY=
LLM_PRIMARY_MODEL=claude-haiku-4-5-20251001
LLM_FALLBACK_MODEL=gemini-2.5-flash
RC_LOG_LEVEL=INFO

# ---- Optional: source health monitoring ------------------------------------
SOURCE_HEALTH_TIMEOUT_SEC=8
SOURCE_HEALTH_MAX_RETRIES=2
SOURCE_HEALTH_USER_AGENT=research-commons-source-health/0.1
SOURCE_HEALTH_REPORT_DIR=reports/source_health
SOURCE_HEALTH_KEYWORDS=

# Reuses the same Resend-style email variables as sibling projects.
RESEND_API_KEY=
RESEND_FROM=alerts@example.com
EMAIL_TO=recipient@example.com
EMAIL_USER=recipient.com
EMAIL_PASS=
